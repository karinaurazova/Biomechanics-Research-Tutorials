{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Setup project .venv",
      "type": "shell",
      "command": "bash",
      "args": [
        "scripts/setup_venv_unix.sh"
      ],
      "windows": {
        "command": "cmd",
        "args": [
          "/c",
          "scripts\\setup_venv_windows.bat"
        ]
      },
      "problemMatcher": []
    },
    {
      "label": "Diagnose environment",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/python",
      "args": [
        "scripts/diagnose_environment.py"
